#define VULN_DB_SIZE ((int)(sizeof(VULN_DB) / sizeof(VULN_DB[0])))

/* ============================================================
 * 탐색 결과 구조체
 * ============================================================ */

typedef struct VulnMatch {
    const VulnFuncEntry *entry;
    uint64_t             addr;
    struct VulnMatch    *next;
} VulnMatch;

typedef struct {
    VulnMatch *head;
    int        count;
    int        count_by_cat[CAT_COUNT];
    int        count_by_sev[5];   /* index 1~4 사용 */
} ScanResult;

/* ============================================================
 * elf_t  :  로드된 ELF 바이너리의 모든 정보를 담는 공개 구조체.
 *           외부 코드는 이 타입을 직접 다룬다.
 * ============================================================ */

typedef struct {
    /* ── 원본 파일 메타 ───────────────────────────── */
    char     path[4096];     /* 파일 경로 (로드 시 복사)  */
    uint8_t *base;           /* mmap 시작 포인터          */
    size_t   file_size;      /* 파일 전체 크기 (bytes)    */

    /* ── ELF 헤더 요약 ───────────────────────────── */
    int      is64;           /* 1 = ELF64,  0 = ELF32    */
    uint16_t e_type;         /* ET_EXEC / ET_DYN / …      */
    uint16_t e_machine;      /* EM_X86_64 / EM_ARM / …   */
    uint64_t e_entry;        /* 진입점 주소               */

    /* ── 동적 심볼 테이블 (.dynsym) ─────────────── */
    uint8_t *dynsym;         /* .dynsym 섹션 포인터       */
    size_t   dynsym_entsz;   /* 심볼 엔트리 크기          */
    size_t   dynsym_cnt;     /* 심볼 개수                 */

    /* ── 동적 문자열 테이블 (.dynstr) ───────────── */
    char    *dynstr;         /* .dynstr 섹션 포인터       */
    size_t   dynstr_sz;      /* .dynstr 크기 (bytes)      */
} elf_t;

/* ============================================================
 * 내부 유틸리티
 * ============================================================ */

static const VulnFuncEntry *lookup_vuln(const char *name) {
    for (int i = 0; i < VULN_DB_SIZE; i++)
        if (strcmp(VULN_DB[i].name, name) == 0)
            return &VULN_DB[i];
    return NULL;
}

static void result_add(ScanResult *res, const VulnFuncEntry *e, uint64_t addr) {
    VulnMatch *m = malloc(sizeof(*m));
    if (!m) return;
    m->entry = e; m->addr = addr; m->next = res->head;
    res->head = m; res->count++;
    res->count_by_cat[e->category]++;
    if (e->severity >= 1 && e->severity <= 4) res->count_by_sev[e->severity]++;
}

static void result_free(ScanResult *res) {
    VulnMatch *cur = res->head;
    while (cur) { VulnMatch *nx = cur->next; free(cur); cur = nx; }
    res->head = NULL;
}

/* ============================================================
 * ELF 로더  :  파일 → elf_t
 * ============================================================ */

/*
 * elf_load()
 *   path 의 ELF 파일을 mmap 하여 elf_t 를 채운다.
 *   성공 시 힙에 할당된 elf_t * 반환, 실패 시 NULL.
 *   사용 후 반드시 elf_free() 로 해제해야 한다.
 */
elf_t *elf_load(const char *path) {
    if (!path) return NULL;

    int fd = open(path, O_RDONLY);
    if (fd < 0) { perror("open"); return NULL; }

    struct stat st;
    if (fstat(fd, &st) < 0) { perror("fstat"); close(fd); return NULL; }
    if (st.st_size < (off_t)EI_NIDENT) {
        fprintf(stderr, "elf_load: file too small\n"); close(fd); return NULL;
    }

    uint8_t *base = mmap(NULL, st.st_size, PROT_READ, MAP_PRIVATE, fd, 0);
    close(fd);
    if (base == MAP_FAILED) { perror("mmap"); return NULL; }

    /* ELF 매직 확인 */
    if (memcmp(base, ELFMAG, SELFMAG) != 0) {
        fprintf(stderr, "elf_load: not an ELF file: %s\n", path);
        munmap(base, st.st_size); return NULL;
    }

    elf_t *elf = calloc(1, sizeof(elf_t));
    if (!elf) { munmap(base, st.st_size); return NULL; }

    strncpy(elf->path, path, sizeof(elf->path) - 1);
    elf->base      = base;
    elf->file_size = (size_t)st.st_size;
    elf->is64      = (base[EI_CLASS] == ELFCLASS64);

    /* 헤더 요약 및 섹션 파싱 */
    if (elf->is64) {
        Elf64_Ehdr *eh = (Elf64_Ehdr *)base;
        elf->e_type    = eh->e_type;
        elf->e_machine = eh->e_machine;
        elf->e_entry   = eh->e_entry;

        if (!eh->e_shoff || !eh->e_shnum) goto done;
        Elf64_Shdr *sh    = (Elf64_Shdr *)(base + eh->e_shoff);
        char       *shstr = (char *)(base + sh[eh->e_shstrndx].sh_offset);
        for (int i = 0; i < eh->e_shnum; i++) {
            const char *n = shstr + sh[i].sh_name;
            if (!strcmp(n, ".dynstr")) {
                elf->dynstr    = (char *)(base + sh[i].sh_offset);
                elf->dynstr_sz = sh[i].sh_size;
            }
            if (!strcmp(n, ".dynsym")) {
                elf->dynsym      = base + sh[i].sh_offset;
                elf->dynsym_entsz = sh[i].sh_entsize
                                  ? sh[i].sh_entsize : sizeof(Elf64_Sym);
                elf->dynsym_cnt  = sh[i].sh_size / elf->dynsym_entsz;
            }
        }
    } else {
        Elf32_Ehdr *eh = (Elf32_Ehdr *)base;
        elf->e_type    = eh->e_type;
        elf->e_machine = eh->e_machine;
        elf->e_entry   = eh->e_entry;

        if (!eh->e_shoff || !eh->e_shnum) goto done;
        Elf32_Shdr *sh    = (Elf32_Shdr *)(base + eh->e_shoff);
        char       *shstr = (char *)(base + sh[eh->e_shstrndx].sh_offset);
        for (int i = 0; i < eh->e_shnum; i++) {
            const char *n = shstr + sh[i].sh_name;
            if (!strcmp(n, ".dynstr")) {
                elf->dynstr    = (char *)(base + sh[i].sh_offset);
                elf->dynstr_sz = sh[i].sh_size;
            }
            if (!strcmp(n, ".dynsym")) {
                elf->dynsym      = base + sh[i].sh_offset;
                elf->dynsym_entsz = sh[i].sh_entsize
                                  ? sh[i].sh_entsize : sizeof(Elf32_Sym);
                elf->dynsym_cnt  = sh[i].sh_size / elf->dynsym_entsz;
            }
        }
    }

done:
    if (!elf->dynstr || !elf->dynsym) {
        fprintf(stderr, "elf_load: .dynsym / .dynstr not found: %s\n", path);
        munmap(base, st.st_size);
        free(elf);
        return NULL;
    }
    return elf;
}

/*
 * elf_free()
 *   elf_load() 로 얻은 elf_t 를 해제한다.
 */
void elf_free(elf_t *elf) {
    if (!elf) return;
    if (elf->base) munmap(elf->base, elf->file_size);
    free(elf);
}

/* ============================================================
 * 취약 함수 탐색  :  elf_t * → ScanResult
 * ============================================================ */

/*
 * elf_scan_vuln_funcs()
 *   이미 로드된 elf_t 를 받아 .dynsym 을 순회하며
 *   VULN_DB 와 매칭되는 취약 함수를 찾아 out 에 저장한다.
 *   반환값: 0 성공, -1 인자 오류, -2 심볼 테이블 없음
 */
int elf_scan_vuln_funcs(const elf_t *elf, ScanResult *out) {
    if (!elf || !out) return -1;
    memset(out, 0, sizeof(*out));

    if (!elf->dynsym || !elf->dynstr) {
        fprintf(stderr, "elf_scan_vuln_funcs: no symbol table in %s\n", elf->path);
        return -2;
    }

    for (size_t i = 0; i < elf->dynsym_cnt; i++) {
        uint64_t val = 0;
        uint32_t ni  = 0;

        if (elf->is64) {
            Elf64_Sym *s = (Elf64_Sym *)(elf->dynsym + i * elf->dynsym_entsz);
            ni = s->st_name; val = s->st_value;
        } else {
            Elf32_Sym *s = (Elf32_Sym *)(elf->dynsym + i * elf->dynsym_entsz);
            ni = s->st_name; val = s->st_value;
        }

        if (ni >= elf->dynstr_sz) continue;
        const char *sym = elf->dynstr + ni;
        if (!*sym) continue;

        const VulnFuncEntry *e = lookup_vuln(sym);
        if (e) result_add(out, e, val);
    }
    return 0;
}

/*
 * elf_scan_from_path()
 *   편의 래퍼: path 로드 → 스캔 → elf_free 까지 한 번에 처리.
 *   elf_t 를 직접 다룰 필요가 없을 때 사용한다.
 *   반환값: 0 성공, 음수 오류
 */
int elf_scan_from_path(const char *path, ScanResult *out) {
    elf_t *elf = elf_load(path);
    if (!elf) return -1;
    int ret = elf_scan_vuln_funcs(elf, out);
    elf_free(elf);
    return ret;
}

/* ============================================================
 * 출력 함수
 * ============================================================ */

/* 심각도 → 레이블 */
static const char *sev_label(int s) {
    switch (s) {
        case 4: return "CRITICAL";
        case 3: return "HIGH    ";
        case 2: return "MEDIUM  ";
        default: return "LOW     ";
    }
}

/* 심각도 → 컬러 */
static const char *sev_color(int s) {
    switch (s) {
        case 4: return COL_RED;
        case 3: return COL_YELLOW;
        case 2: return COL_CYAN;
        default: return COL_GRAY;
    }
}

/* 반복 문자 출력 헬퍼 */
static void print_line(char ch, int n) {
    for (int i = 0; i < n; i++) putchar(ch);
    putchar('\n');
}

/* ──────────────────────────────────────────────────────────
 * print_banner()
 *   스캔 시작 헤더를 출력한다.
 *   path : 분석 대상 ELF 경로
 * ────────────────────────────────────────────────────────── */
void print_banner(const char *path) {
    printf("\n%s%s", C(COL_BOLD), C(COL_CYAN));
    print_line('=', 72);
    printf("  ELF Vulnerability Scanner\n");
    printf("  Target : %s\n", path);
    printf("%s%s", C(COL_RESET), C(COL_CYAN));
    print_line('=', 72);
    printf("%s\n", C(COL_RESET));
}

/* ──────────────────────────────────────────────────────────
 * print_result_table()
 *   탐색된 취약 함수 목록을 심각도 내림차순 테이블로 출력한다.
 *   결과가 없으면 "No vulnerable functions detected." 출력.
 * ────────────────────────────────────────────────────────── */
void print_result_table(const ScanResult *res) {
    if (res->count == 0) {
        printf("%s[+] No vulnerable functions detected.%s\n\n",
               C(COL_GREEN), C(COL_RESET));
        return;
    }

    /* 심각도 내림차순 정렬을 위한 임시 배열 */
    VulnMatch **arr = malloc(sizeof(VulnMatch *) * res->count);
    if (!arr) return;

    int idx = 0;
    for (VulnMatch *m = res->head; m; m = m->next)
        arr[idx++] = m;

    /* 버블 정렬 */
    for (int i = 0; i < idx - 1; i++)
        for (int j = i + 1; j < idx; j++)
            if (arr[j]->entry->severity > arr[i]->entry->severity) {
                VulnMatch *tmp = arr[i]; arr[i] = arr[j]; arr[j] = tmp;
            }

    /* 테이블 헤더 */
    printf("%s%s", C(COL_BOLD), C(COL_WHITE));
    printf("  %-10s  %-14s  %-14s  %-18s  %s\n",
           "SEVERITY", "CATEGORY", "FUNCTION", "ADDRESS", "REASON");
    printf("%s%s", C(COL_RESET), C(COL_GRAY));
    print_line('-', 90);
    printf("%s", C(COL_RESET));

    /* 각 행 출력 */
    for (int i = 0; i < idx; i++) {
        const VulnFuncEntry *e = arr[i]->entry;
        printf("  %s%-10s%s  %s%-14s%s  %s%-14s%s  0x%016llx  %s\n",
               g_use_color ? sev_color(e->severity)       : "", sev_label(e->severity),  C(COL_RESET),
               g_use_color ? CATEGORY_COLORS[e->category] : "", CATEGORY_NAMES[e->category], C(COL_RESET),
               C(COL_BOLD), e->name, C(COL_RESET),
               (unsigned long long)arr[i]->addr,
               e->reason);
    }

    printf("%s", C(COL_GRAY));
    print_line('-', 90);
    printf("%s\n", C(COL_RESET));

    free(arr);
}

/* ──────────────────────────────────────────────────────────
 * print_detail_report()
 *   함수별 상세 정보 (카테고리, 주소, 위험 이유, 권장 대체 함수)
 *   를 번호를 붙여 순서대로 출력한다.
 * ────────────────────────────────────────────────────────── */
void print_detail_report(const ScanResult *res) {
    if (res->count == 0) return;

    printf("%s%s[!] Detailed Report%s\n", C(COL_BOLD), C(COL_WHITE), C(COL_RESET));
    printf("%s", C(COL_GRAY));
    print_line('-', 72);
    printf("%s", C(COL_RESET));

    int no = 1;
    for (VulnMatch *m = res->head; m; m = m->next, no++) {
        const VulnFuncEntry *e = m->entry;
        printf("  %s[%02d]%s %s%s%s  —  %s%s%s\n",
               C(COL_BOLD), no, C(COL_RESET),
               C(COL_BOLD), e->name, C(COL_RESET),
               g_use_color ? sev_color(e->severity) : "", sev_label(e->severity), C(COL_RESET));
        printf("       Category : %s%s%s\n",
               g_use_color ? CATEGORY_COLORS[e->category] : "",
               CATEGORY_NAMES[e->category], C(COL_RESET));
        printf("       Address  : 0x%016llx\n", (unsigned long long)m->addr);
        printf("       Risk     : %s\n", e->reason);
        printf("       Safe Alt : %s%s%s\n\n",
               C(COL_GREEN), e->safe_alt, C(COL_RESET));
    }
}

/* ──────────────────────────────────────────────────────────
 * print_summary()
 *   전체 탐색 결과를 심각도별 / 카테고리별로 집계하여
 *   통계 요약을 출력한다.
 * ────────────────────────────────────────────────────────── */
void print_summary(const ScanResult *res) {
    printf("%s%s[*] Summary%s\n", C(COL_BOLD), C(COL_WHITE), C(COL_RESET));
    printf("%s", C(COL_GRAY));
    print_line('-', 72);
    printf("%s", C(COL_RESET));

    printf("  Total vulnerable functions : %s%s%d%s\n\n",
           C(COL_BOLD),
           res->count > 0 ? C(COL_RED) : C(COL_GREEN),
           res->count, C(COL_RESET));

    /* 심각도별 카운트 */
    static const char *sev_names[] = { "", "LOW", "MEDIUM", "HIGH", "CRITICAL" };
    printf("  By Severity:\n");
    for (int s = 4; s >= 1; s--) {
        if (!res->count_by_sev[s]) continue;
        printf("    %s%-10s%s : %d\n",
               g_use_color ? sev_color(s) : "", sev_names[s], C(COL_RESET),
               res->count_by_sev[s]);
    }

    /* 카테고리별 카운트 */
    printf("\n  By Category:\n");
    for (int c = 0; c < CAT_COUNT; c++) {
        if (!res->count_by_cat[c]) continue;
        printf("    %s%-14s%s : %d\n",
               g_use_color ? CATEGORY_COLORS[c] : "",
               CATEGORY_NAMES[c], C(COL_RESET),
               res->count_by_cat[c]);
    }

    printf("\n%s", C(COL_GRAY));
    print_line('=', 72);
    printf("%s\n", C(COL_RESET));
}

/* ──────────────────────────────────────────────────────────
 * print_report()  ← 단일 파일 최상위 출력 함수
 *   내부적으로 아래 순서로 출력한다:
 *     1. print_banner()
 *     2. print_result_table()
 *     3. print_detail_report()
 *     4. print_summary()
 * ────────────────────────────────────────────────────────── */
void print_report(const char *path, const ScanResult *res) {
    print_banner(path);
    print_result_table(res);
    print_detail_report(res);
    print_summary(res);
}

/* ============================================================
 * 다중 파일 배치 스캔
 * ============================================================ */

/*
 * BatchEntry  : 파일 1개의 스캔 결과를 보관하는 구조체
 * BatchResult : 업로드된 파일 전체의 스캔 결과 배열
 */
typedef struct {
    char       path[4096];   /* 파일 경로 */
    ScanResult result;       /* 취약 함수 탐색 결과 */
    int        scan_err;     /* 0=성공, 음수=오류 코드 */
} BatchEntry;

typedef struct {
    BatchEntry *entries;     /* 동적 배열 */
    int         count;       /* 파일 수 */
    int         total_vulns; /* 전체 취약 함수 수 (모든 파일 합산) */
} BatchResult;

/* ──────────────────────────────────────────────────────────
 * batch_scan()
 *   paths[]  : 스캔할 ELF 파일 경로 배열
 *   n        : 파일 수
 *   out      : 결과를 채울 BatchResult 포인터
 *
 *   각 파일에 대해 elf_scan_vuln_funcs()를 호출하고
 *   결과를 BatchEntry 배열에 저장한다.
 *   반환값: 0 성공, -1 메모리 할당 실패
 * ────────────────────────────────────────────────────────── */
int batch_scan(const char **paths, int n, BatchResult *out) {
    if (!paths || n <= 0 || !out) return -1;
    memset(out, 0, sizeof(*out));

    out->entries = calloc(n, sizeof(BatchEntry));
    if (!out->entries) return -1;
    out->count = n;

    for (int i = 0; i < n; i++) {
        BatchEntry *be = &out->entries[i];
        strncpy(be->path, paths[i], sizeof(be->path) - 1);

        be->scan_err = elf_scan_from_path(paths[i], &be->result);
        if (be->scan_err == 0)
            out->total_vulns += be->result.count;
    }
    return 0;
}

/* batch_free() : BatchResult 내 모든 ScanResult 메모리 해제 */
void batch_free(BatchResult *br) {
    if (!br || !br->entries) return;
    for (int i = 0; i < br->count; i++)
        result_free(&br->entries[i].result);
    free(br->entries);
    br->entries = NULL;
}

/* ──────────────────────────────────────────────────────────
 * print_batch_overview()
 *   배치 스캔 전체 현황을 한눈에 볼 수 있는 요약 테이블 출력.
 *   파일명 | 취약 함수 수 | Critical/High/Medium/Low 건수
 * ────────────────────────────────────────────────────────── */
void print_batch_overview(const BatchResult *br) {
    printf("\n%s%s", C(COL_BOLD), C(COL_CYAN));
    print_line('=', 80);
    printf("  Batch Scan Overview  (%d file(s) scanned)\n", br->count);
    printf("%s%s", C(COL_RESET), C(COL_CYAN));
    print_line('=', 80);
    printf("%s\n", C(COL_RESET));

    /* 헤더 */
    printf("%s%s  %-3s  %-40s  %5s  %4s  %4s  %4s  %4s%s\n",
           C(COL_BOLD), C(COL_WHITE),
           "No.", "FILE", "TOTAL", "CRIT", "HIGH", "MED", "LOW",
           C(COL_RESET));
    printf("%s", C(COL_GRAY));
    print_line('-', 80);
    printf("%s", C(COL_RESET));

    for (int i = 0; i < br->count; i++) {
        const BatchEntry *be = &br->entries[i];

        /* 파일명만 추출 (경로에서 basename) */
        const char *fname = strrchr(be->path, '/');
        fname = fname ? fname + 1 : be->path;

        if (be->scan_err != 0) {
            /* 스캔 오류 행 */
            printf("  %s%-3d%s  %-40s  %sERROR (code %d)%s\n",
                   C(COL_GRAY), i + 1, C(COL_RESET),
                   fname,
                   C(COL_RED), be->scan_err, C(COL_RESET));
            continue;
        }

        const ScanResult *r = &be->result;
        int crit = r->count_by_sev[4];
        int high = r->count_by_sev[3];
        int med  = r->count_by_sev[2];
        int low  = r->count_by_sev[1];

        /* 총합 컬러: 0=초록, Critical 있으면 빨강, 아니면 노랑 */
        const char *total_col = r->count == 0 ? C(COL_GREEN)
                              : crit > 0       ? C(COL_RED)
                                               : C(COL_YELLOW);

        printf("  %-3d  %-40s  %s%5d%s  %s%4d%s  %s%4d%s  %4d  %4d\n",
               i + 1, fname,
               total_col, r->count, C(COL_RESET),
               crit > 0 ? C(COL_RED)    : C(COL_GRAY), crit, C(COL_RESET),
               high > 0 ? C(COL_YELLOW) : C(COL_GRAY), high, C(COL_RESET),
               med, low);
    }

    printf("%s", C(COL_GRAY));
    print_line('-', 80);
    printf("%s", C(COL_RESET));

    /* 전체 합산 */
    printf("\n  %sTotal vulnerabilities across all files : %s%d%s\n\n",
           C(COL_BOLD),
           br->total_vulns > 0 ? C(COL_RED) : C(COL_GREEN),
           br->total_vulns, C(COL_RESET));
}

/* ──────────────────────────────────────────────────────────
 * print_batch_report()  ← 배치 최상위 출력 함수
 *   1. print_batch_overview() : 전체 요약 테이블
 *   2. 파일별로 print_report() : 상세 리포트
 * ────────────────────────────────────────────────────────── */
void print_batch_report(const BatchResult *br) {
    print_batch_overview(br);

    for (int i = 0; i < br->count; i++) {
        const BatchEntry *be = &br->entries[i];
        if (be->scan_err != 0) {
            printf("%s[!] Skipping %s — scan error %d%s\n\n",
                   C(COL_RED), be->path, be->scan_err, C(COL_RESET));
            continue;
        }
        /* 파일이 1개뿐이거나 취약 함수가 있는 파일만 상세 출력 */
        if (br->count == 1 || be->result.count > 0)
            print_report(be->path, &be->result);
    }
}

/* ============================================================
 * main
 * ============================================================ */

static void usage(const char *prog) {
    fprintf(stderr,
        "Usage: %s [options] <elf_file> [elf_file2 ...]\n"
        "Options:\n"
        "  -n   Disable color output\n"
        "  -h   Show this help\n"
        "\n"
        "Examples:\n"
        "  %s ./target                   # 단일 파일 스캔\n"
        "  %s ./a.out ./b.out ./c.so     # 다중 파일 배치 스캔\n",
        prog, prog, prog);
}

int main(int argc, char *argv[]) {
    int opt;
    while ((opt = getopt(argc, argv, "nh")) != -1) {
        switch (opt) {
            case 'n': g_use_color = 0; break;
            case 'h': usage(argv[0]); return 0;
            default:  usage(argv[0]); return 1;
        }
    }

    int file_count = argc - optind;
    if (file_count <= 0) { usage(argv[0]); return 1; }

    const char **paths = (const char **)&argv[optind];

    BatchResult batch;
    if (batch_scan(paths, file_count, &batch) < 0) {
        fprintf(stderr, "Failed to allocate batch result\n");
        return 1;
    }

    print_batch_report(&batch);
    batch_free(&batch);
    return 0;
}
